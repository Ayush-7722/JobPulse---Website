# ─── Server ───────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/jobpulse?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────
JWT_SECRET=jobpulse_change_this_to_something_long_and_random_in_production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ─── Email (OTP) ──────────────────────────
# Get Gmail App Password: Google Account → Security → 2-Step → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ─── RapidAPI (LinkedIn Jobs - optional) ──
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_LINKEDIN_HOST=linkedin-jobs-api2.p.rapidapi.com
